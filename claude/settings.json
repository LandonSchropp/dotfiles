{
  "env": {
    "CLAUDE_CODE_DISABLE_FEEDBACK_SURVEY": "1",
    "ENABLE_CLAUDEAI_MCP_SERVERS": "false"
  },
  "includeCoAuthoredBy": false,
  "permissions": {
    "allow": [
      "Bash(brew *)",
      "Bash(bun *)",
      "Bash(bundle exec *)",
      "Bash(cd *)",
      "Bash(find *)",
      "Bash(git *)",
      "Bash(just *)",
      "Bash(ls *)",
      "Bash(mise *)",
      "Bash(npm *)",
      "Bash(npx *)",
      "Bash(pnpm *)",
      "Bash(rg *)",
      "Bash(shellcheck *)",
      "Bash(trash *)",
      "Bash(wc *)",
      "Bash(flashspace *)",
      "Bash(playwright-cli *)",
      "Bash(yarn *)",
      "Read(./**)"
    ],
    "deny": [
      "Read(.env)",
      "Read(**/.env*)",
      "Read(**/.secret*)",
      "Read(**/*.pem)",
      "Read(**/*.key)",
      "Read(**/*.crt)",
      "Read(**/*.cert)",
      "Read(**/secrets/**)",
      "Read(**/credentials/**)"
    ],
    "ask": [
      "Bash(git commit *)",
      "Bash(git push *)",
      "Bash(git rebase *)",
      "Bash(git reset *)",
      "Bash(git clean *)"
    ],
    "additionalDirectories": ["~/Notes", "~/Development", "~/.claude"]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/prettier"
          },
          {
            "type": "command",
            "command": "~/.claude/hooks/rubocop"
          },
          {
            "type": "command",
            "command": "~/.claude/hooks/shfmt"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/notification"
          }
        ]
      }
    ],
    "Notification": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/notification"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "npx -y ccstatusline@latest",
    "padding": 0
  },
  "extraKnownMarketplaces": {
    "oysterhr": {
      "source": {
        "source": "directory",
        "path": "/Users/landon/Development/oyster-agent-toolkit"
      }
    },
    "landonschropp": {
      "source": {
        "source": "directory",
        "path": "/Users/landon/Development/agent-toolkit"
      }
    },
    "writing": {
      "source": {
        "source": "directory",
        "path": "/Users/landon/Development/writing-toolkit"
      }
    }
  },
  "enabledPlugins": {
    "Notion@claude-plugins-official": true,
    "typescript-lsp@claude-plugins-official": true,
    "context7@claude-plugins-official": true,
    "playwright@claude-plugins-official": false,
    "linear@claude-plugins-official": true,
    "ruby-lsp@claude-plugins-official": true,
    "notion@claude-plugins-official": true,
    "oyster-development@oyster-agent-toolkit": true,
    "oyster-backend@oyster-agent-toolkit": true,
    "oyster-frontend@oyster-agent-toolkit": true,
    "oyster-agent-toolkit@oyster-agent-toolkit": true,
    "oyster-team-inex@oyster-agent-toolkit": true,
    "ls@landonschropp": true,
    "writing@writing": true
  },
  "syntaxHighlightingDisabled": true,
  "alwaysThinkingEnabled": true,
  "voiceEnabled": true,
  "skipAutoPermissionPrompt": true
}
