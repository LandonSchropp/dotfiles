#!/usr/bin/env bash

set -euo pipefail

function print_help() {
  echo "Usage: review [revdiff-args...]"
  echo
  echo "Run revdiff and paste its annotations into the Claude agent in the current"
  echo "herdr workspace, then press Enter."
  echo
  echo "All arguments are forwarded to revdiff."
  echo
  echo "Options:"
  echo
  echo "  --help                Show this help message and exit."
  echo
  echo "Examples:"
  echo
  echo "  review HEAD~1"
  echo "  review --staged"
}

revdiff_args=()

while [[ $# -gt 0 ]]; do
  case "$1" in
  --help)
    print_help
    exit 0
    ;;
  *)
    revdiff_args+=("$1")
    shift
    ;;
  esac
done

if [[ -z "${HERDR_WORKSPACE_ID:-}" ]]; then
  echo "Error: review must be run inside herdr." >&2
  exit 1
fi

target=$(herdr agent list |
  jq -r --arg workspace "$HERDR_WORKSPACE_ID" \
    'first(.result.agents[]
       | select(.agent == "claude" and .workspace_id == $workspace)
       | .pane_id) // empty')

if [[ -z "$target" ]]; then
  echo "Error: No Claude agent found in workspace '$HERDR_WORKSPACE_ID'." >&2
  exit 1
fi

output_file=$(mktemp)
trap 'rm -f "$output_file"' EXIT

revdiff --output="$output_file" ${revdiff_args[@]+"${revdiff_args[@]}"}

if [[ ! -s "$output_file" ]]; then
  exit 0
fi

# TODO: Remove this stdout fallback once the herdr paste path is reliable.
cat "$output_file"

# Bracketed paste, so newlines don't submit a message each.
herdr agent send "$target" "$(printf '\033[200~%s\033[201~' "$(cat "$output_file")")" >/dev/null

# Submit the pasted block.
herdr agent send "$target" $'\n' >/dev/null
