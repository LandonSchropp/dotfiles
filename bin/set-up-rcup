#!/usr/bin/env bash

set -euo pipefail

hostname="$(hostname -s)"

if [[ "$hostname" == OHR* ]]; then
  tag="work"
else
  tag="personal"
fi

rcup \
  -t "$tag" \
  -v \
  -U Library \
  -x config/karabiner/karabiner.json \
  Library \
  claude \
  config \
  local \
  tmux.conf \
  zprofile \
  zshenv \
  zshrc

# HACK: Karabiner-Elements saves karabiner.json by writing a new file and renaming it over the
# target, which clobbers any symlink placed at that path. In order to work around this, I have to
# symlink the config directory instead.
rm -rf "$HOME/.config/karabiner"
ln -s "$HOME/.dotfiles/config/karabiner" "$HOME/.config/karabiner"
