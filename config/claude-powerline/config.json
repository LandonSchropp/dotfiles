{
  "theme": "tokyo-night",
  "display": {
    "style": "capsule",
    "colorCompatibility": "auto",
    "lines": [
      {
        "segments": {
          "model": { "enabled": true },
          "version": { "enabled": true },
          "context": { "enabled": true, "showPercentageOnly": false },
