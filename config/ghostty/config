# Set the font to my preferences
font-family = "JetBrainsMono Nerd Font Mono"
font-size = 19
font-style = Medium

# Disable ligatures
font-feature = -calt, -liga, -dlig

# Set the theme to Tokyo Night Storm
theme = "TokyoNight Storm"

# Ensure that new windows take up the full screen size.
window-width = 1000
window-height = 1000

# Increase the window padding so the characters don't bump up against the edge
window-padding-x = 4

# Don't display the resize overlay
resize-overlay = never

# Increase the line height
adjust-cell-height = 25%

# Automatically download updates
auto-update = download

# Override the default cursor style
cursor-style = "block"
shell-integration-features = no-cursor

# Release these keys instead of letting Ghostty intercept them, so herdr can bind them directly.
keybind = command+h=unbind
keybind = command+l=unbind
keybind = command+t=unbind
keybind = command+w=unbind
keybind = command+n=unbind
keybind = command+j=unbind
keybind = command+k=unbind

# Disable the toggle fullscreen keybinding.
keybind = super+enter=unbind

# Make the shift+enter keybinding insert a newline
keybind = shift+enter=text:\n

# Make alt keys behave normally
macos-option-as-alt = false

# Always open the Development directory
working-directory = /Users/landon/Development
